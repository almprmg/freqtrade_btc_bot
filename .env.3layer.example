# Copy to .env.3layer and fill values. Do NOT commit .env.3layer.

# L3_AGGR_WIDE_GRID won the 16-variant 5-year sweep (+99.6%).
# Others to explore: L3_AGGR_BASELINE (+88.9%, smoother), L3_BAL_WIDE_GRID (+81.9%, lower DD).
FREQTRADE_L3_MODE=L3_AGGR_WIDE_GRID

# Binance Spot API keys. Leave blank for pure dry-run.
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# Bridge — fill these AFTER you create the admin subscription row.
BRIDGE_3LAYER_SUBSCRIPTION_ID=
BRIDGE_3LAYER_USER_ID=
TRAD_PG_DSN=
BRIDGE_POLL_INTERVAL=30
