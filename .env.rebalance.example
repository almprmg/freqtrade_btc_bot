# Copy to .env.rebalance and fill values. Do NOT commit .env.rebalance.

# R5_75_BTC won the 5-year sweep (+166%). To explore: R1_DAILY_FULL (+115%, 50/50),
# R6_HALFWAY (+120%, smoother), R4_25_BTC (+54%, defensive).
FREQTRADE_REBALANCE_MODE=R5_75_BTC

# Binance Spot API keys. Leave blank to run in pure dry_run (the config has
# dry_run=true so even with keys the bot won't trade until you flip it).
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=
