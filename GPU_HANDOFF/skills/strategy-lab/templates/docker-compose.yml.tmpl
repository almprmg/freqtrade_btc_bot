# {{ bot_name }} — {{ hypothesis_short }}
# Backtest: {{ backtest_summary }}
# Adversarial: {{ adversarial_verdict }}

services:
  freqtrade_{{ slug }}:
    image: freqtradeorg/freqtrade:2026.4
    container_name: freqtrade_{{ slug }}
    restart: unless-stopped
    environment:
      FREQTRADE__EXCHANGE__KEY: ${FREQTRADE__EXCHANGE__KEY:-}
      FREQTRADE__EXCHANGE__SECRET: ${FREQTRADE__EXCHANGE__SECRET:-}
    volumes:
      - ./user_data:/freqtrade/user_data
      - ./config.{{ slug }}.json:/freqtrade/config.json:ro
    command: >
      trade --logfile /freqtrade/user_data/logs/freqtrade_{{ slug }}.log
      --db-url sqlite:////freqtrade/user_data/tradesv3_{{ slug }}.sqlite
      --config /freqtrade/config.json --strategy {{ ClassName }}Strategy
    networks: [default, trad_system_trad]

  freqtrade_{{ slug }}_bridge:
    image: freqtrade-bridge:latest
    container_name: freqtrade_{{ slug }}_bridge
    restart: unless-stopped
    depends_on: [freqtrade_{{ slug }}]
    environment:
      BRIDGE_SUBSCRIPTION_ID: ${BRIDGE_{{ SLUG_UPPER }}_SUB}
      BRIDGE_USER_ID: ${BRIDGE_USER_ID:-10}
      FREQTRADE_SQLITE_PATH: /data/freqtrade/tradesv3_{{ slug }}.sqlite
      TRAD_PG_DSN: ${TRAD_PG_DSN}
      POLL_INTERVAL_SECONDS: ${BRIDGE_POLL_INTERVAL:-30}
    volumes: [./user_data:/data/freqtrade:ro]
    networks: [default, trad_system_trad]

networks:
  trad_system_trad:
    external: true
