# Copy to .env.dca and fill in real values.
# Do NOT commit .env.dca.

# Pick the mode chosen after the 5-year sweep — V5_TIERED was the winner
# (+40% net over 5 years vs +17% for blind V1).
FREQTRADE_DCA_MODE=V5_TIERED

# Binance Spot API keys. Leave blank to run in pure dry_run (the config
# has dry_run=true so even with keys the bot won't trade until you flip it).
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=
